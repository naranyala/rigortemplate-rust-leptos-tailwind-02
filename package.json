{
  "scripts": {
    "tailwind:build": "./node_modules/.bin/tailwindcss -i ./input.css -o ./output.css",
    "tailwind:watch": "./node_modules/.bin/tailwindcss -i ./input.css -o ./output.css --watch",
    "dev": "PORT=$(./scripts/find-port.sh) && bun concurrently \"bun run tailwind:watch\" \"trunk serve --port $PORT\"",
    "build": "bun run tailwind:build && trunk build --release",
    "docs": "cargo doc --no-deps"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0"
  }
}
